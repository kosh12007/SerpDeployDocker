# =============================================================
# Шаблон переменных окружения для проекта Serp
# Скопируйте этот файл: cp .env.example .env
# Затем заполните все значения своими данными
# =============================================================

# --- API XMLRiver (поисковая выдача) ---
# Получить на https://xmlriver.com
API_KEY=http://xmlriver.com/search/xml?user=ВАШИ_USER&key=ВАШ_API_KEY

# --- Настройки базы данных MySQL ---
# В Docker окружении DB_HOST = имя сервиса в docker-compose (db)
DB_HOST=db
DB_PORT=3306
DB_NAME=serp_db
DB_USER=serp_user
DB_PASSWORD=замените_на_надёжный_пароль

# Пароль root для MySQL (используется только при инициализации)
MYSQL_ROOT_PASSWORD=замените_на_root_пароль

# --- Flask ---
# Сгенерируйте ключ командой:
# python -c "import secrets; print(secrets.token_hex(24))"
SECRET_KEY=замените_на_случайный_ключ_32символа

# --- Режим запуска ---
# local — разработка, hosting — продакшн
MODE=local

# --- ИИ (DeepSeek API) ---
# Опционально: для AI-аналитики
DEEPSEEK_API_KEY=ваш_deepseek_api_key

# --- Логирование ---
# true — писать логи в файлы, false — отключить
LOGGING_ENABLED=true

# --- Ограничения ---
# Количество потоков OpenBLAS (важно для shared-хостинга)
OPENBLAS_NUM_THREADS=1

# --- Настройки почты (Flask-Mail) ---
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=ваш_email@example.com
MAIL_PASSWORD=пароль_от_почты
MAIL_DEFAULT_SENDER=ваш_email@example.com

# --- Файлы (оставить по умолчанию) ---
INPUT_FILE=queries.xlsx
OUTPUT_FILE=results.xlsx
RETRY_ATTEMPTS=5
RETRY_DELAY=10
